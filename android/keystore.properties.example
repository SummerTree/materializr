# Copy this file to `keystore.properties` (same dir) and fill in your values.
# The real keystore.properties is gitignored — NEVER commit it or the .jks.
# build.gradle reads these to sign release builds (assembleRelease / bundleRelease).

# Absolute path to the keystore you generated with keytool (see RELEASE-SIGNING.md).
storeFile=/home/kevin/materializr-release.jks

# The keystore password you chose when running keytool.
storePassword=CHANGE_ME

# The key alias (RELEASE-SIGNING.md uses "materializr").
keyAlias=materializr

# The key password you chose (often the same as storePassword).
keyPassword=CHANGE_ME
